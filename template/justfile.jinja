{% set include_target_test_cov = "test-cov" in justfile_targets %}
{% set include_target_e2e = "e2e" in justfile_targets %}
{% set include_target_pre_commit = "pre-commit" in justfile_targets %}
{% set include_target_commitizen = "commitizen" in justfile_targets %}
{% set include_target_complexity = "complexity" in justfile_targets %}
{% set include_target_vulture = "vulture" in justfile_targets %}
{% set include_target_darglint = "darglint" in justfile_targets %}
{% set include_target_docstr_coverage = "docstr-coverage" in justfile_targets %}
{% set include_target_audit = "audit" in justfile_targets %}
{% set include_target_bandit = "bandit" in justfile_targets %}
{% set include_target_radon = "radon" in justfile_targets %}
{% set include_target_find_dupes = "find-dupes" in justfile_targets %}
{% set include_target_docs_frontmatter_fix = "docs-frontmatter-fix" in justfile_targets %}
{% set quality_deps = "format lint types test docs-check" %}
{% if include_target_complexity %}{% set quality_deps = quality_deps ~ " complexity" %}{% endif %}
{% if include_target_vulture %}{% set quality_deps = quality_deps ~ " vulture" %}{% endif %}
{% if include_target_darglint %}{% set quality_deps = quality_deps ~ " darglint" %}{% endif %}
{% if include_target_audit %}{% set quality_deps = quality_deps ~ " audit" %}{% endif %}
{% if include_target_bandit %}{% set quality_deps = quality_deps ~ " bandit" %}{% endif %}
{% if include_target_radon %}{% set quality_deps = quality_deps ~ " radon" %}{% endif %}
{% if include_target_find_dupes %}{% set quality_deps = quality_deps ~ " find-dupes" %}{% endif %}
{% if include_target_docstr_coverage %}{% set quality_deps = quality_deps ~ " docstr-coverage" %}{% endif %}
{% set quality_check_deps = "format-check lint-check types test docs-check" %}
{% if include_target_complexity %}{% set quality_check_deps = quality_check_deps ~ " complexity" %}{% endif %}
{% if include_target_vulture %}{% set quality_check_deps = quality_check_deps ~ " vulture" %}{% endif %}
{% if include_target_darglint %}{% set quality_check_deps = quality_check_deps ~ " darglint" %}{% endif %}
{% if include_target_audit %}{% set quality_check_deps = quality_check_deps ~ " audit" %}{% endif %}
{% if include_target_bandit %}{% set quality_check_deps = quality_check_deps ~ " bandit" %}{% endif %}
{% if include_target_radon %}{% set quality_check_deps = quality_check_deps ~ " radon" %}{% endif %}
{% if include_target_find_dupes %}{% set quality_check_deps = quality_check_deps ~ " find-dupes" %}{% endif %}
{% if include_target_docstr_coverage %}{% set quality_check_deps = quality_check_deps ~ " docstr-coverage" %}{% endif %}
{% set quality_dev_deps = "format lint types" %}
{% if include_target_darglint %}{% set quality_dev_deps = quality_dev_deps ~ " darglint" %}{% endif %}
# Justfile for {{ project_name }}

set windows-shell := ["pwsh.exe", "-NoLogo", "-Command"]
set shell := ["sh", "-cu"]

# Run all tests.
test:
    uv run pytest

{% if include_target_e2e %}
# Run end-to-end tests only (if tests/e2e exists).
e2e:
    if [ -d tests/e2e ]; then uv run pytest tests/e2e; else echo "No tests/e2e directory; skipping."; fi
{% endif %}

{% if include_target_test_cov %}
# Run tests with coverage report.
test-cov:
    uv run pytest --cov=src/{{ package_name }} --cov-report=term-missing --cov-report=html
{% endif %}

# Format code (ruff).
format:
    uv run ruff format .

# Check formatting only (CI; no write).
format-check:
    uv run ruff format --check .

# Lint and auto-fix (ruff).
lint:
    uv run ruff check --fix .

# Lint check only (CI; no fix).
lint-check:
    uv run ruff check .

# Type-check (mypy).
types:
    uv run mypy -p {{ package_name }}

{% if include_target_complexity %}
# Complexity check (xenon): max-absolute B, max-modules A, max-average A.
complexity:
    uv run xenon -b B -m A -a A src
{% endif %}

{% if include_target_vulture %}
# Dead-code check (vulture); config in pyproject.toml.
vulture:
    uv run vulture
{% endif %}

{% if include_target_darglint %}
# Docstring correctness (darglint), Google style, full strictness.
darglint:
    uv run darglint -s google -z full src
{% endif %}

{% if include_target_docstr_coverage %}
# Docstring coverage on public API (skip private, magic, __init__).
docstr-coverage:
    uv run docstr-coverage src --skip-private --skip-magic --skip-init -v 2
{% endif %}

{% if include_target_audit %}
# Security: dependency vulnerabilities (pip-audit).
audit:
    uv run pip-audit
{% endif %}

{% if include_target_bandit %}
# Security: static analysis (bandit).
bandit:
    uv run bandit -r src
{% endif %}

{% if include_target_radon %}
# Maintainability index (radon); fail if any module below C.
radon:
    uv run radon mi src -n C
{% endif %}

{% if include_target_find_dupes %}
# Find duplicate code (pylint duplicate-code checker).
find-dupes:
    uv run pylint src/{{ package_name }} --disable=all --enable=duplicate-code --min-similarity-lines=10
{% endif %}

{% if include_target_commitizen %}
# Conventional commits: interactive commit (Commitizen).
commit:
    uv run cz commit

# Check that commit message(s) follow conventional commits.
commit-check:
    uv run cz check
{% endif %}

{% if include_target_pre_commit %}
# Install pre-commit hooks (run once). Includes commit-msg hook.
pre-commit-install:
    uv run pre-commit install
    uv run pre-commit install --hook-type commit-msg

# Run pre-commit on all files.
pre-commit:
    uv run pre-commit run --all-files
{% endif %}

# Run full quality suite.
quality: {{ quality_deps }}

# Check-only quality suite for CI.
quality-check: {{ quality_check_deps }}

# Lighter day-to-day quality lane.
quality-dev: {{ quality_dev_deps }}

# Validate docs frontmatter values and active-doc staleness.
docs-check:
    uv run python scripts/validate_docs_frontmatter.py --max-active-age-days 21

{% if include_target_docs_frontmatter_fix %}
# Auto-add placeholder frontmatter to docs missing frontmatter.
docs-frontmatter-fix:
    uv run python scripts/validate_docs_frontmatter.py --fix --max-active-age-days 21
{% endif %}

# Show one-command project/docs execution status summary.
status:
    uv run python scripts/status_report.py

# Run docs validation plus status summary in one command.
status-ready: docs-check status
